# ========== Anthropic ==========
# console.anthropic.com/settings/keys 에서 발급 (이름: ai-agency-automation)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ========== Supabase ==========
# 신규 프로젝트 ai-agency-prod 생성 후 Settings → API
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJXXXXXXX       # ⚠️ 서버 전용, 절대 클라이언트 노출 X
SUPABASE_ANON_KEY=eyJXXXXXXX               # 읽기 전용 공개 키

# ========== Slack ==========
# 에이전시 운영 채널용 Incoming Webhook.
# 클라이언트별 채널 분기는 DB (clients.slack_channel_webhook) 에서 관리.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXXXXXXXXX

# ========== Meta / Instagram Graph API (W5~) ==========
# 에이전시 단일 Meta 앱. 클라이언트 IG 계정은 OAuth로 연결 후 DB에 토큰 저장.
# (clients.ig_user_id, clients.ig_long_lived_token)
META_APP_ID=
META_APP_SECRET=

# ========== 운영 설정 ==========
# ⚠️ CLIENT_SLUG 은 env 에 두지 않는다.
# 멀티테넌트 설계 원칙: 클라이언트는 DB clients 테이블 row 로만 존재.
# 에이전트는 client_slug 를 인자로 받아 실행.
TIMEZONE=Asia/Seoul
LOG_LEVEL=INFO
ENV=development                             # development | production
